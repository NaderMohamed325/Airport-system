  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Passenger",
          "request": {
            "url": "{{url}}",
            "method": "POST",
            "headers": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation RegisterPassenger($input: CreatePassengerInput!) {\n  registerPassenger(createPassengerInput: $input) {\n    createdAt\n    email\n    id\n    isActive\n    name\n    nationality\n    passportNumber\n    role\n    updatedAt\n  }\n}",
                "variables": "{\n  \"input\": {\n    \"name\": \"John Doe\",\n    \"email\": \"john@example.com\",\n    \"password\": \"SecurePass123!\",\n    \"nationality\": \"American\",\n    \"passportNumber\": \"P12345678\"\n  }\n}"
              }
            }
          }
        },
        {
          "name": "Login Passenger",
          "request": {
            "url": "{{url}}",
            "method": "POST",
            "headers": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation LoginPassenger($input: LoginPassengerInput!) {\n  loginPassenger(loginPassengerInput: $input) {\n    accessToken\n    email\n    id\n    isActive\n    name\n    role\n  }\n}",
                "variables": "{\n  \"input\": {\n    \"email\": \"john@example.com\",\n    \"password\": \"SecurePass123!\"\n  }\n}"
              }
            },
            "event": [
              {
                "listen": "test",
                "script": {
                  "exec": [
                    "const jsonData = pm.response.json();",
                    "if (jsonData.data?.loginPassenger?.accessToken) {",
                    "  pm.collectionVariables.set('token', jsonData.data.loginPassenger.accessToken);",
                    "}"
                  ]
                }
              }
            ]
          }
        },
        {
          "name": "Register Staff",
          "request": {
            "url": "{{url}}",
