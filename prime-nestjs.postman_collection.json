                "query": "mutation LoginStaff($input: LoginPassengerInput!) {\n  loginStaff(loginStaffInput: $input) {\n    accessToken\n    email\n    id\n    isActive\n    name\n    role\n  }\n}",
                "variables": "{\n  \"input\": {\n    \"email\": \"admin@example.com\",\n    \"password\": \"AdminPass123!\"\n  }\n}"
              }
            },
