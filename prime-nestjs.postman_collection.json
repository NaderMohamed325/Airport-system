              "graphql": {
                "query": "mutation RegisterStaff($input: CreateStaffInput!) {\n  registerStaff(createStaffInput: $input) {\n    createdAt\n    email\n    id\n    isActive\n    name\n    role\n    updatedAt\n  }\n}",
                "variables": "{\n  \"input\": {\n    \"name\": \"Admin User\",\n    \"email\": \"admin@example.com\",\n    \"password\": \"AdminPass123!\",\n    \"role\": \"admin\"\n  }\n}"
              }
